#!/bin/bash

###############################################################################
# cloudshell-vars.env — Variables genéricas (CAMBIAR AQUÍ)
#
# Estos son los ÚNICOS valores que necesitas editar
# El resto se genera automáticamente
###############################################################################

# ═══════════════════════════════════════════════════════════════════════════
# 1️⃣  IDENTIFICADORES (CAMBIAR ESTO PRIMERO)
# ═══════════════════════════════════════════════════════════════════════════

PROJECT_NAME="examlab"              # Nombre del proyecto (minúsculas, sin espacios)
ENVIRONMENT="production"            # production | staging | development
AWS_REGION="us-east-1"             # Region AWS (us-east-1, eu-west-1, etc)
OWNER_NAME="YourName"              # Nombre del dueño (para tags)
COST_CENTER="engineering"          # Centro de costos

# ═══════════════════════════════════════════════════════════════════════════
# 2️⃣  GITHUB (Para clonar repo automáticamente)
# ═══════════════════════════════════════════════════════════════════════════

GITHUB_OWNER="tu-usuario"          # Tu usuario de GitHub (ej: vivetori)
GITHUB_REPO="examlab"              # Nombre del repo (ej: examlab)
GITHUB_BRANCH="main"               # Branch a deployar (main, develop, etc)

# Ejemplo completo:
# Tu repo está en: https://github.com/vivetori/examlab
# Entonces:
#   GITHUB_OWNER="vivetori"
#   GITHUB_REPO="examlab"

# ═══════════════════════════════════════════════════════════════════════════
# 3️⃣  INFRAESTRUCTURA EC2
# ═══════════════════════════════════════════════════════════════════════════

EC2_INSTANCE_TYPE="t3.small"       # t3.micro | t3.small | t3.medium (presupuesto)
EC2_MIN_SIZE="1"                   # Mínimo de instancias (Auto Scaling)
EC2_MAX_SIZE="2"                   # Máximo de instancias
EC2_DESIRED_SIZE="1"               # Instancias iniciales

# Almacenamiento
EC2_DISK_SIZE="30"                 # GB de disco

# ═══════════════════════════════════════════════════════════════════════════
# 4️⃣  BASE DE DATOS RDS (PostgreSQL)
# ═══════════════════════════════════════════════════════════════════════════

DB_INSTANCE_TYPE="db.t3.micro"     # db.t3.micro | db.t3.small (presupuesto)
DB_STORAGE_SIZE="20"               # GB iniciales
DB_STORAGE_MAX="100"               # GB máximo (auto-scaling)
DB_ENGINE_VERSION="15.4"           # PostgreSQL version

DB_NAME="examlab"                  # Nombre de la BD
DB_USERNAME="postgres"             # Usuario admin

# ⚠️  CAMBIAR CONTRASEÑA - Mínimo 8 caracteres, letras + números
DB_PASSWORD="ExamLab2024ChangeMe!" # !!!CAMBIAR!!!

# Backups
DB_BACKUP_RETENTION="7"            # Días de retención

# ═══════════════════════════════════════════════════════════════════════════
# 5️⃣  APLICACIÓN (Node.js)
# ═══════════════════════════════════════════════════════════════════════════

APP_PORT="3000"                    # Puerto Node.js
NODE_VERSION="20"                  # Node.js version (16, 18, 20, etc)

# ═══════════════════════════════════════════════════════════════════════════
# 6️⃣  SUPABASE (Si usas Supabase)
# ═══════════════════════════════════════════════════════════════════════════

SUPABASE_URL="https://xxxxx.supabase.co"      # Tu proyecto Supabase
SUPABASE_ANON_KEY="eyJhbGc..."                # Clave anon pública
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."        # Clave service role

# Edge Functions para IA
SUPABASE_AI_GENERATE_FUNCTION="ai-generate"         # Generar preguntas/contenido
SUPABASE_AI_GRADE_FUNCTION="ai-grade"              # Calificar respuestas
SUPABASE_AI_FEEDBACK_FUNCTION="ai-feedback"        # Retroalimentación personalizada

# ═══════════════════════════════════════════════════════════════════════════
# 7️⃣  HTTPS/SSL (Futuro - No editar ahora)
# ═══════════════════════════════════════════════════════════════════════════

ENABLE_HTTPS="false"               # true | false (implementar después)
ACM_CERTIFICATE_ARN=""             # arn:aws:acm:... (para después)

# ═══════════════════════════════════════════════════════════════════════════
# 8️⃣  MONITOREO Y LOGS
# ═══════════════════════════════════════════════════════════════════════════

ENABLE_CLOUDWATCH_LOGS="true"      # true | false
LOG_RETENTION_DAYS="7"             # Días de retención

# ═══════════════════════════════════════════════════════════════════════════
# 9️⃣  BACKUP Y RECUPERACIÓN
# ═══════════════════════════════════════════════════════════════════════════

BACKUP_ENABLED="true"              # true | false
BACKUP_BUCKET_NAME=""              # S3 bucket para backups (auto-generado si vacío)

# ═══════════════════════════════════════════════════════════════════════════
# AUTO-GENERADAS (No editar, se generan automáticamente)
# ═══════════════════════════════════════════════════════════════════════════

# Stack names
VPC_STACK_NAME="${PROJECT_NAME}-vpc-${ENVIRONMENT}"
RDS_STACK_NAME="${PROJECT_NAME}-rds-${ENVIRONMENT}"
EC2_STACK_NAME="${PROJECT_NAME}-ec2-${ENVIRONMENT}"
MAIN_STACK_NAME="${PROJECT_NAME}-main-${ENVIRONMENT}"

# Names
SSH_KEY_NAME="${PROJECT_NAME}-${ENVIRONMENT}"
SECURITY_GROUP_NAME="${PROJECT_NAME}-sg-${ENVIRONMENT}"
ALB_NAME="${PROJECT_NAME}-alb-${ENVIRONMENT}"

# Paths
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLOUDFORMATION_DIR="${SCRIPT_DIR}/cloudformation"
SCRIPTS_DIR="${SCRIPT_DIR}/scripts"
CONFIGS_DIR="${SCRIPT_DIR}/configs"

# Timestamps
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ═══════════════════════════════════════════════════════════════════════════
# VALIDACIONES
# ═══════════════════════════════════════════════════════════════════════════

validate_variables() {
    local errors=0

    # Validar nombres
    if [[ ! $PROJECT_NAME =~ ^[a-z0-9-]+$ ]]; then
        echo -e "${RED}✗${NC} PROJECT_NAME debe ser minúsculas, números y guiones"
        errors=$((errors+1))
    fi

    # Validar DB password
    if [[ ${#DB_PASSWORD} -lt 8 ]]; then
        echo -e "${RED}✗${NC} DB_PASSWORD debe tener mínimo 8 caracteres"
        errors=$((errors+1))
    fi

    if [[ ! $DB_PASSWORD =~ [0-9] ]]; then
        echo -e "${RED}✗${NC} DB_PASSWORD debe contener números"
        errors=$((errors+1))
    fi

    if [[ ! $DB_PASSWORD =~ [a-zA-Z] ]]; then
        echo -e "${RED}✗${NC} DB_PASSWORD debe contener letras"
        errors=$((errors+1))
    fi

    # Validar GitHub config (si se va a usar)
    if [[ -n "$GITHUB_REPO" && -z "$GITHUB_OWNER" ]]; then
        echo -e "${RED}✗${NC} GITHUB_OWNER requerido si GITHUB_REPO está configurado"
        errors=$((errors+1))
    fi

    if [[ $errors -gt 0 ]]; then
        echo ""
        echo -e "${RED}Error: $errors validación(es) fallaron${NC}"
        return 1
    fi

    return 0
}

# ═══════════════════════════════════════════════════════════════════════════
# INFORMACIÓN
# ═══════════════════════════════════════════════════════════════════════════

print_info() {
    echo -e "\n${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║            CONFIGURACIÓN DE DEPLOYMENTO                    ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}\n"
    echo "Proyecto:            $PROJECT_NAME"
    echo "Ambiente:            $ENVIRONMENT"
    echo "Region:              $AWS_REGION"
    echo ""
    echo "EC2:                 $EC2_INSTANCE_TYPE (Auto Scaling: $EC2_MIN_SIZE-$EC2_MAX_SIZE)"
    echo "RDS:                 $DB_INSTANCE_TYPE ($DB_STORAGE_SIZE GB)"
    echo "Node.js:             v$NODE_VERSION"
    echo "GitHub:              $GITHUB_OWNER/$GITHUB_REPO ($GITHUB_BRANCH)"
    echo ""
}

# Export variables para otros scripts
export PROJECT_NAME ENVIRONMENT AWS_REGION OWNER_NAME COST_CENTER
export GITHUB_OWNER GITHUB_REPO GITHUB_BRANCH
export EC2_INSTANCE_TYPE EC2_MIN_SIZE EC2_MAX_SIZE EC2_DESIRED_SIZE EC2_DISK_SIZE
export DB_INSTANCE_TYPE DB_STORAGE_SIZE DB_STORAGE_MAX DB_ENGINE_VERSION
export DB_NAME DB_USERNAME DB_PASSWORD DB_BACKUP_RETENTION
export APP_PORT NODE_VERSION
export SUPABASE_URL SUPABASE_ANON_KEY SUPABASE_SERVICE_ROLE_KEY
export ENABLE_HTTPS ACM_CERTIFICATE_ARN
export ENABLE_CLOUDWATCH_LOGS LOG_RETENTION_DAYS
export BACKUP_ENABLED BACKUP_BUCKET_NAME
export VPC_STACK_NAME RDS_STACK_NAME EC2_STACK_NAME MAIN_STACK_NAME
export SSH_KEY_NAME SECURITY_GROUP_NAME ALB_NAME
export SCRIPT_DIR CLOUDFORMATION_DIR SCRIPTS_DIR CONFIGS_DIR TIMESTAMP
export RED GREEN YELLOW BLUE NC
