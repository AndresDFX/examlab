      "beats": [
        {
          "target": "card:Generar con IA",
          "scale": 1.15,
          "hold": 2200,
          "side": "bottom",
          "focus": {
            "title": "Generar con IA",
            "body": "Temas, cantidad y tipos de pregunta."
