    {
      "id": "outro",
      "kind": "card",
      "narration": "En el siguiente módulo: los talleres.",
      "card": {
        "kicker": "ExamLab · Rol Docente",
        "title": "Siguiente módulo",
        "subtitle": "Talleres"
      },
