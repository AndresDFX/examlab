      "beats": [
        {
          "target": "#exam-questions-list",
          "scale": 1.12,
          "hold": 9500,
          "side": "right",
          "scroll": true,
          "focus": {
            "title": "Listas para revisar",
            "body": "Edita el enunciado, el puntaje o elimina las que no convenzan."
