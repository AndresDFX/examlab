      "card": {
        "kicker": "ExamLab · Rol Docente",
        "title": "Preguntas con IA",
        "subtitle": "Generación en vivo"
      },
      "bufferMs": 600
    },
    {
      "id": "ia-vivo",
      "kind": "platform",
      "tab": "Preguntas",
