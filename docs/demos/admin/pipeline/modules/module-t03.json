        {
          "target": "field:Descripción",
          "hold": 3000,
          "side": "right",
          "syncWord": "descripción",
          "focus": {
            "title": "Descripción",
            "body": "Indicaciones generales."
          }
        },
        {
          "target": "field:Fin",
          "hold": 3000,
          "side": "right",
          "syncWord": "fecha",
          "focus": {
            "title": "Cierre",
            "body": "Fecha y hora límite."
          }
        },
        {
          "target": "field:Navegación",
          "hold": 4200,
          "side": "right",
          "syncWord": "navegación",
          "focus": {
            "title": "Navegación",
            "body": "Libre o secuencial entre preguntas."
          }
        }
