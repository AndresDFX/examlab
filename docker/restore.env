# Template para el restore en Docker. Copia este archivo a `restore.env`
# (en este mismo directorio docker/) y completa los valores.
#
#   Copy-Item docker/restore.env.example docker/restore.env
#
# El archivo `restore.env` está cubierto por el patrón `.env.*` del
# .gitignore — no se commitea.

# Ref del nuevo proyecto Supabase (el subdominio antes de .supabase.co).
# Ej: si tu URL es https://abcdef123456.supabase.co, esto va: abcdef123456

NEW_SUPABASE_DB_URL=postgresql://postgres.uxxpzfsfcnqiwwdxoelm:sDoCBpAaaCYwWAUS@aws-1-us-east-1.pooler.supabase.com:5432/postgres
NEW_SUPABASE_PROJECT_REF=https://uxxpzfsfcnqiwwdxoelm.supabase.co

# Password de la DB del nuevo proyecto (la que pusiste al crear el proyecto).
NEW_SUPABASE_DB_PASSWORD=sDoCBpAaaCYwWAUS

# Región del nuevo proyecto. Aparece en Project Settings → General.
# Ejemplos: us-east-1, us-east-2, eu-west-1, sa-east-1
NEW_SUPABASE_REGION=us-east-1

# service_role key del NUEVO proyecto.
# Dashboard del nuevo → Project Settings → API → service_role (secret).
NEW_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV4eHB6ZnNmY25xaXd3ZHhvZWxtIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODM0MjI4OSwiZXhwIjoyMDkzOTE4Mjg5fQ.lGDNQCuk8F6Gf8fiL2CjKCvFVMetFIMuxun-W8ORobo

# Personal Access Token de Supabase para el CLI (deploy de edge functions).
# Empieza con sbp_... Se genera en https://supabase.com/dashboard/account/tokens
NEW_SUPABASE_ACCESS_TOKEN=sbp_1937758279606c482ffbe0f33d50898ad2cd3ea6

# Opcional: password temporal asignada a TODOS los users migrados.
# Si no se setea, default = "Temporal#123456".
# DEFAULT_PASSWORD=MiPasswordCustom#456
