# Template para el restore en Docker. Copia este archivo a `restore.env`
# (en este mismo directorio docker/) y completa los valores.
#
#   Copy-Item docker/restore.env.example docker/restore.env
#
# El archivo `restore.env` está cubierto por el patrón `.env.*` del
# .gitignore — no se commitea.

# Ref del nuevo proyecto Supabase (el subdominio antes de .supabase.co).
# Ej: si tu URL es https://abcdef123456.supabase.co, esto va: abcdef123456
# Tambien acepta la URL completa — el script extrae el ref.
NEW_SUPABASE_PROJECT_REF=

# ─────────────────────────────────────────────────────────────────
# Conexion a la DB — usar UNA de las dos opciones:
# ─────────────────────────────────────────────────────────────────
#
# OPCION A (RECOMENDADA): pegar el connection string completo.
# Dashboard del nuevo Supabase → Project Settings → Database →
# Connection string → pestana "Session" (puerto 5432) → copia la URI
# y reemplaza [YOUR-PASSWORD] con la password real de la DB.
#
# Si esta variable esta seteada, el script la usa y IGNORA password/region.
#
# NEW_SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# OPCION B: pasar password + region y el script arma el connection string.
# Solo se usa si NEW_SUPABASE_DB_URL queda vacio. Menos confiable porque
# el hostname del pooler cambia entre proyectos (aws-0-, aws-1-, etc.).
NEW_SUPABASE_DB_PASSWORD=
NEW_SUPABASE_REGION=us-east-1

# service_role key del NUEVO proyecto.
# Dashboard del nuevo → Project Settings → API → service_role (secret).
NEW_SUPABASE_SERVICE_ROLE_KEY=

# Personal Access Token de Supabase para el CLI (deploy de edge functions).
# Empieza con sbp_... Se genera en https://supabase.com/dashboard/account/tokens
NEW_SUPABASE_ACCESS_TOKEN=

# Opcional: password temporal asignada a TODOS los users migrados.
# Si no se setea, default = "Temporal#123456".
# DEFAULT_PASSWORD=MiPasswordCustom#456
