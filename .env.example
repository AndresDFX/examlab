# ═══════════════════════════════════════════════════════════════════════════════
# ExamLab — Archivo de configuración
#
# IMPORTANTE:
# 1. Copia este archivo a .env
# 2. NO commitees .env a Git (está en .gitignore)
# 3. Reemplaza los valores según tu entorno
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 📋 Información del Proyecto
# ─────────────────────────────────────────────────────────────────────────────

PROJECT_NAME=examlab
ENVIRONMENT=production
OWNER_NAME=Developer
COST_CENTER=engineering

# ─────────────────────────────────────────────────────────────────────────────
# 🌍 AWS Configuration
# ─────────────────────────────────────────────────────────────────────────────

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJal...

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️  PostgreSQL & Supabase
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_secure_password_12_chars_minimum
POSTGRES_DB=examlab

# URLs
SUPABASE_URL=http://localhost:8000
POSTGRES_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Keys (cambiar en producción)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImV4YW1sYWIiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTYwMzk0OTgwMCwiZXhwIjoxNjM0NDgwODAwfQ.MOCK_KEY_CHANGE_IN_SUPABASE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImV4YW1sYWIiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjAzOTQ5ODAwLCJleHAiOjE2MzQ0ODA4MDB9.MOCK_KEY_CHANGE_IN_SUPABASE

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 Node.js & Application
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# 🤖 Supabase Edge Functions (AI)
# ─────────────────────────────────────────────────────────────────────────────

# Nombres de las funciones edge en Supabase
SUPABASE_AI_GENERATE_FUNCTION=ai-generate
SUPABASE_AI_GRADE_FUNCTION=ai-grade
SUPABASE_AI_FEEDBACK_FUNCTION=ai-feedback

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 Security
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=change_me_to_a_very_secure_random_string_minimum_32_chars
JWT_EXPIRY=3600

# ─────────────────────────────────────────────────────────────────────────────
# 🐳 Docker
# ─────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=${PROJECT_NAME}

# ─────────────────────────────────────────────────────────────────────────────
# 💾 Backup Configuration
# ─────────────────────────────────────────────────────────────────────────────

BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=7
BACKUP_BUCKET_NAME=

# ─────────────────────────────────────────────────────────────────────────────
# 📊 Monitoring & Logging
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info
ENABLE_CLOUDWATCH_LOGS=true
LOG_RETENTION_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 GitHub (Opcional)
# ─────────────────────────────────────────────────────────────────────────────

GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# ─────────────────────────────────────────────────────────────────────────────
# EC2 Configuration (AWS)
# ─────────────────────────────────────────────────────────────────────────────

EC2_INSTANCE_TYPE=t3.small
EC2_MIN_SIZE=1
EC2_MAX_SIZE=2
EC2_DESIRED_SIZE=1
EC2_DISK_SIZE=30

# ─────────────────────────────────────────────────────────────────────────────
# RDS Configuration (AWS)
# ─────────────────────────────────────────────────────────────────────────────

DB_INSTANCE_TYPE=db.t3.micro
DB_STORAGE_SIZE=20
DB_STORAGE_MAX=100
DB_ENGINE_VERSION=15.4
DB_NAME=examlab
DB_USERNAME=postgres
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_BACKUP_RETENTION=7

# ─────────────────────────────────────────────────────────────────────────────
# VPC Configuration (AWS)
# ─────────────────────────────────────────────────────────────────────────────

VPC_CIDR=10.0.0.0/16
PUBLIC_SUBNET_1_CIDR=10.0.1.0/24
PUBLIC_SUBNET_2_CIDR=10.0.2.0/24
PRIVATE_SUBNET_1_CIDR=10.0.10.0/24
PRIVATE_SUBNET_2_CIDR=10.0.11.0/24
DB_SUBNET_1_CIDR=10.0.20.0/24
DB_SUBNET_2_CIDR=10.0.21.0/24

# ─────────────────────────────────────────────────────────────────────────────
# ℹ️  Nota para usuarios finales
# ─────────────────────────────────────────────────────────────────────────────
#
# Este archivo se genera automáticamente con `bash setup.sh`
# No necesitas editarlo manualmente a menos que sepas lo que haces.
#
# Valores importantes a cambiar:
# - POSTGRES_PASSWORD (base de datos)
# - JWT_SECRET (seguridad)
# - AWS_ACCESS_KEY_ID y AWS_SECRET_ACCESS_KEY (si desplegas a AWS)
# ─────────────────────────────────────────────────────────────────────────────
