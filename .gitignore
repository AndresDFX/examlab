# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro
*.local

# Vitest coverage output (se sube como artifact en CI, no commit)
coverage/
.nyc_output/

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Env files (never commit)
.env
.env.*
!.env.example

# Backup dumps — contienen datos personales (emails, nombres). Mantener
# los .sql en local pero nunca commitearlos. La documentacion del proceso
# de migracion vive en docs/migration/.
backup/
!backup/.gitkeep

# Supabase CLI temp (se crea al hacer `supabase link`).
supabase/.temp/

# Outputs de `bun run record:tour:*` — videos .webm pesados que se suben
# a HeyGen como background; no van al repo. Las credenciales del usuario
# demo (DEMO_EMAIL / DEMO_PASSWORD) viven en .env.recording, también
# ignorado por el patrón `.env.*` arriba, pero lo explicito acá por claridad.
recordings/
.env.recording
